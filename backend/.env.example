# MySQL settings for production. If MySQL is not running, SQLite demo DB is used automatically.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=trading_brokerage
USE_SQLITE_FALLBACK=true
SQLITE_PATH=trading_brokerage_demo.db
JWT_SECRET_KEY=change-this-secret-in-production
JWT_EXPIRY_HOURS=24
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
